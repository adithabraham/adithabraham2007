#5. Design a blog layout using HTML and CSS

<!DOCTYPE html>
<html>
<head>
    <title>My Blog</title>

    <style>
        body {
            font-family: Arial;
            margin: 0;
            background-color: #f4f4f4;
        }

        header {
            background: #333;
            color: white;
            padding: 15px;
            text-align: center;
        }

        nav {
            background: #555;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
        }

        .container {
            display: flex;
            margin: 20px;
        }

        .posts {
            width: 70%;
        }

        .post {
            background: white;
            padding: 15px;
            margin-bottom: 20px;
        }

        .sidebar {
            width: 30%;
            background: #ddd;
            padding: 15px;
            margin-left: 20px;
        }

        footer {
            background: #333;
            color: white;
            text-align: center;
            padding: 10px;
        }
    </style>
</head>

<body>

<header>
    <h1>My Blog</h1>
    <p>Simple Blog Layout</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">About</a>
    <a href="#">Contact</a>
</nav>

<div class="container">

    <!-- Blog Posts -->
    <div class="posts">

        <div class="post">
            <h2>First Blog Post</h2>
            <p>This is a simple blog post content.</p>
        </div>

        <div class="post">
            <h2>Second Blog Post</h2>
            <p>This is another blog post content.</p>
        </div>

    </div>

    <!-- Sidebar -->
    <div class="sidebar">
        <h3>Categories</h3>
        <ul>
            <li>Technology</li>
            <li>Education</li>
            <li>Lifestyle</li>
        </ul>

        <h3>Recent Posts</h3>
        <ul>
            <li>Post One</li>
            <li>Post Two</li>
        </ul>
    </div>

</div>

<footer>
    <p>© 2026 My Blog</p>
</footer>

</body>
</html>